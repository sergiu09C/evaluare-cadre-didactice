# Server Configuration
PORT=5001
NODE_ENV=development

# Database
# Local dev: leave as default (uses backend/src/db/evaluare.db)
# Production (Railway): set to /data/evaluare.db (path inside persistent volume)
DB_PATH=./src/db/evaluare.db

# JWT Secret (MUST be a long random string in production!)
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Session
SESSION_EXPIRY=24h

# CORS — comma-separated list of allowed frontend origins (production only)
# Example: CORS_ORIGIN=https://evaluareacadrelordidactice.ro
CORS_ORIGIN=

# Email (SMTP via Resend / Brevo / etc.) — required only if password reset / notifications are used
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
