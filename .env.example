# Copiere ca .env (sau setează pe Railway în Variables):
#
# JWT_SECRET — semnătura tokenelor de autentificare. OBLIGATORIU în producție.
#   Generează: openssl rand -hex 32
JWT_SECRET=replace_me_with_long_random_hex_string

# NODE_ENV — comutator pentru: rate-limit strict, servire frontend static, log level.
#   Folosește "production" pe Railway; "development" local.
NODE_ENV=production

# PORT — Railway setează automat. Local poate fi 5001 (default 5000).
PORT=5001

# DB_PATH — locația fișierului SQLite.
#   Pe Railway: setează "/data/evaluare.db" și montează un Volume pe /data
#   ca să persistă DB-ul între deploy-uri.
DB_PATH=./src/db/evaluare.db

# CORS_ORIGIN — origini permise (separate prin virgulă).
#   În single-service deploy (Railway), backend servește și frontend din același
#   domeniu, deci CORS nu e strict necesar. Dacă folosești frontend separat,
#   pune URL-ul exact: https://your-frontend.up.railway.app
CORS_ORIGIN=https://YOUR-APP.up.railway.app

# SERVE_FRONTEND — forțează servirea frontend dist din backend chiar dacă
# NODE_ENV != "production" (util pe staging/preview).
SERVE_FRONTEND=true
